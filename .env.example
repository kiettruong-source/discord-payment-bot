# ─────────────────────────────────────────────
# Discord Bot Configuration
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here

# Role name that is allowed to use payment commands (case-insensitive)
SUPPORT_ROLE_NAME=support

# ─────────────────────────────────────────────
# Your Vietnamese Bank Details
# ─────────────────────────────────────────────
# Bank BIN / ID – find yours at https://api.vietqr.io/v2/banks
# Common examples:
#   970422 = MB Bank
#   970436 = Vietcombank
#   970418 = BIDV
#   970432 = VPBank
#   970407 = Techcombank
#   970405 = Agribank
BANK_ID=970422
BANK_NAME=MB Bank
BANK_ACCOUNT_NO=0123456789
BANK_ACCOUNT_NAME=NGUYEN VAN A

# ─────────────────────────────────────────────
# VietQR API Credentials (optional but recommended)
# Get free keys at: https://developers.vietqr.io/
# Without keys, basic generation still works but is rate-limited
# ─────────────────────────────────────────────
VIETQR_CLIENT_ID=
VIETQR_API_KEY=

# ─────────────────────────────────────────────
# Booking Rates (VND per hour)
# ─────────────────────────────────────────────
RATE_DAY=25000
RATE_NIGHT=30000
