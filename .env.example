# ─────────────────────────────────────────────
# Discord Bot Configuration
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here


# Role name that is allowed to use payment commands (case-insensitive)
SUPPORT_ROLE_NAME= admin

# ─────────────────────────────────────────────
# Your Vietnamese Bank Details
# ─────────────────────────────────────────────
# Bank BIN / ID – find yours at https://api.vietqr.io/v2/banks
# Common examples:
#   970422 = MB Bank
#   970436 = Vietcombank
#   970418 = BIDV
#   970432 = VPBank
#   970407 = Techcombank
#   970405 = Agribank
BANK_ID=970422
BANK_NAME=MB Bank
BANK_ACCOUNT_NO=0868135605
BANK_ACCOUNT_NAME=LO THI THAO

# ─────────────────────────────────────────────
# VietQR API Credentials (optional but recommended)
# Get free keys at: https://developers.vietqr.io/
# Without keys, basic generation still works but is rate-limited
# ─────────────────────────────────────────────
VIETQR_CLIENT_ID=98fd8b18-1bf5-4d98-bea3-cebd6e6be78a
VIETQR_API_KEY=d1850a3f-e47f-4b4b-855c-5032cff40085

# ─────────────────────────────────────────────
# Booking Rates (VND per hour)
# ─────────────────────────────────────────────
RATE_DAY=25000
RATE_NIGHT=30000
